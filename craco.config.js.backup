const WorkboxPlugin = require('workbox-webpack-plugin');

module.exports = {
  webpack: {
    plugins: {
      add: [
        new WorkboxPlugin.InjectManifest({
          swSrc: './src/service-worker.js',
          swDest: 'service-worker.js',
          maximumFileSizeToCacheInBytes: 10 * 1024 * 1024, // 10MB для 3D-моделей
        }),
      ],
    },
  },
};